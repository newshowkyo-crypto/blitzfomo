# Blitz Fomo production env example
# Copy to `.env.production` on the VPS and fill every value.
# Never commit real secrets.

NODE_ENV=production
DOMAIN=blitzfomo.com

POSTGRES_USER=blitz
POSTGRES_PASSWORD=change_me_strong_postgres_password
POSTGRES_DB=blitz_finale

REDIS_PASSWORD=change_me_strong_redis_password

DATABASE_URL=postgresql://blitz:change_me_strong_postgres_password@postgres:5432/blitz_finale?schema=public
REDIS_URL=redis://:change_me_strong_redis_password@redis:6379

JWT_SECRET=change_me_64_plus_chars_random_secret
BOT_TOKEN=change_me_telegram_bot_token

ADMIN_USERNAME=super_admin
ADMIN_PASSWORD=change_me_strong_admin_password
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=change_me_strong_operator_password

ACTIVE_PAYMENT_GATEWAY=plisio
PLISIO_API_KEY=change_me_plisio_secret_key
PLISIO_ALLOWED_PSYS_CIDS=USDT_TRX,USDT_TON,TON,TRX
PLISIO_SOURCE_CURRENCY=USD
PLISIO_EXPIRE_MIN=60

PUBLIC_API_BASE_URL=https://blitzfomo.com
TMA_PUBLIC_URL=https://blitzfomo.com
PLISIO_SUCCESS_URL=https://blitzfomo.com
PLISIO_FAIL_URL=https://blitzfomo.com
