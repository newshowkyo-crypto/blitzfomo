# Blitz Fomo local development env example
# Copy to `.env` for local testing. Do not commit real secrets.

NODE_ENV=development

DATABASE_URL="postgresql://blitz:blitz_dev_2026@localhost:5434/blitz_finale?schema=public"
REDIS_URL="redis://:blitz_redis_2026@localhost:6381"

JWT_SECRET="change_me_long_random_dev_secret"

# Telegram Mini App login. Required for production TMA auth.
BOT_TOKEN="change_me_telegram_bot_token"

# Admin seed credentials. Replace before any public deployment.
ADMIN_USERNAME="super_admin"
ADMIN_PASSWORD="change_me_admin_password"
OPERATOR_USERNAME="operator"
OPERATOR_PASSWORD="change_me_operator_password"

# Payment gateway
ACTIVE_PAYMENT_GATEWAY="mock"

# Plisio crypto payment gateway. Fill these before switching to Plisio.
PLISIO_API_KEY="change_me_plisio_secret_key"
PLISIO_ALLOWED_PSYS_CIDS="USDT_TRX,USDT_BSC,BTC,ETH,LTC,TRX"
PLISIO_SOURCE_CURRENCY="USD"
PLISIO_EXPIRE_MIN="60"
PUBLIC_API_BASE_URL="http://localhost:8081"
TMA_PUBLIC_URL="http://localhost:8081"
