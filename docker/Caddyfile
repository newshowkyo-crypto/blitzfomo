www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	route {
		@admin_root path /admin
		redir @admin_root /admin/ 308

		@admin path /admin/ /admin/*
		reverse_proxy @admin nginx:80

		@admin_assets path /assets /assets/*
		reverse_proxy @admin_assets nginx:80

		@api path /api /api/*
		reverse_proxy @api nginx:80

		@socket path /socket.io /socket.io/*
		reverse_proxy @socket nginx:80

		handle /stitch_blitz_finale_world_cup_edition/blitz_finale_world_cup_2026_edition/code.html {
			root * /var/www/web
			rewrite * /index.html
			file_server
		}

		handle_path /stitch_blitz_finale_world_cup_edition/* {
			root * /var/www/stitch
			try_files {path} {path}/code.html {path}/index.html
			file_server {
				index code.html index.html
			}
		}

		root * /var/www/web
		try_files {path} {path}/ /index.html
		file_server
	}
}
